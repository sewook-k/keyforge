{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyForge",
  "version": "0.1.19",
  "identifier": "com.keyforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../apps/ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KeyForge",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "visible": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "KeyForge contributors",
    "shortDescription": "Stable global key and mouse remapper",
    "longDescription": "A Windows-first global key and mouse remapper with atomic settings, activity notifications, and real keyboard inventory.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
